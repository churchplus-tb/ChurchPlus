@model EntradaViewModel
@{
    ViewData["Title"] = "Adicionar Entradas";
}
<style>
    .form-container {
        width: 100%;
        padding: 0.1rem;
        border: 1px solid #ccc;
        border-radius: 10px; /* opcional: remove o arredondamento se quiser bordas quadradas */
        box-sizing: border-box; /* garante que padding não estoure a largura */
        background-color: rgba(248, 249, 250, 0);
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .form-group-spacing {
        margin-bottom: 0.5rem; /* Triplo do padrão (~1.33rem) */
    }

    #table-usuarios {
        table-layout: auto !important;
        width: auto !important;
    }

        #table-usuarios th,
        #table-usuarios td {
            white-space: nowrap; /* impede quebra de linha */
            font-size: 12px; /* já reduz o tamanho da fonte */
            padding: 4px 8px; /* opcional: deixa a célula mais compacta */
            color: rgba(0,0,0); /* branco */
        }

        #table-usuarios thead th {
            color: rgba(0,0,0); /* branco esverdeado */
            font-weight: 600;
        }

    .icon-mini {
        font-size: 1.05rem; /* ~12px */
    }

        .icon-mini:hover {
            border-color: #fff; /* borda branca no hover */
            cursor: pointer; /* muda o cursor para indicar clique */
        }

    .botao-transparente {
        background-color: transparent;
        border: 1px solid transparent;
        color: #fff; /* cor do ícone branco */
    }

        .botao-transparente:hover {
            border-color: #fff; /* cor do ícone branco */
            background-color: rgba(0, 0, 0, 0.05);
        }
    /* reset simples */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html, body {
        height: 100%;
    }


    /* BOTÃO NAV */
    .btn-nav {
        padding: 6px 14px;
        border-radius: 10px;
        display: inline-block;
        width: 100%;
        text-align: center;
        font-weight: 600;
        border: 1px solid rgba(230,243,234,0.3);
        backdrop-filter: blur(6px);
        background: linear-gradient(90deg, rgba(70,200,120,0.1), rgba(50,160,90,0.14));
        color: #fff;
        cursor: pointer;
        transition: background 0.3s ease, color 0.3s ease;
    }

        .btn-nav:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

    /* Formulário */
    .form-container {
        width: 100%;
        margin: 0;
        padding: 0.5rem;
        border-radius: 10px;
        background-color: transparent;
        box-sizing: border-box;
    }

    .form-group-spacing {
        margin-bottom: 2rem;
    }

    /* HERO (conteúdo em primeiro plano) */
    .hero {
        min-height: 72vh;
        display: flex;
        align-items: center;
        position: relative;
        z-index: 1;
        padding: 60px 40px;
    }

    .hero-inner {
        max-width: 1100px;
        width: 100%;
        margin: 0 auto;
        padding: 32px;
        position: relative;
        z-index: 3;
    }

    .hero h1 {
        font-size: 48px;
        line-height: 1.02;
        margin-bottom: 12px;
        color: #e9fff1;
        text-shadow: 0 6px 22px rgba(2,10,6,0.5);
    }

    .hero .accent {
        color: #48c878;
    }

    .lead {
        color: rgba(230,243,234,0.8);
        margin-bottom: 18px;
    }

    .hero-cta {
        display: flex;
        gap: 12px;
        margin-bottom: 22px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
    }

        .btn:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }

        .btn.primary {
            background: linear-gradient(90deg, rgba(70,200,120,0.18), rgba(50,160,90,0.14));
            color: #eaffef;
        }

            .btn.primary:hover {
                background: rgba(70,200,120,0.18);
                color: rgba(0,0,0);
                border: 1px solid rgba(0,0,0);
            }

        .btn.ghost {
            background: transparent;
            color: rgba(230,243,234,0.9);
            border: 1px solid rgba(230,243,234,0.08);
        }

            .btn.ghost:hover {
                background: rgba(255,255,255,0.05);
                color: #fff;
            }

    /* cards */
    .cards {
        display: flex;
        gap: 14px;
        margin-top: 18px;
    }

    .card {
        min-width: 200px;
        padding: 14px;
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.12));
        box-shadow: 0 8px 24px rgba(2,10,6,0.45);
        backdrop-filter: blur(6px);
        color: #dff7e8;
    }

    /* rodapé */
    .site-footer {
        padding: 24px;
        text-align: center;
        color: rgba(200,230,210,0.6);
    }

    /* responsividade simples */
    @@media (max-width:900px) {
        .hero h1 {
            font-size: 32px;
        }

        .nav-links {
            display: none;
        }

        .hero {
            padding: 30px;
        }

        .cards {
            flex-direction: column;
        }
    }

    /* textbox */
    .textbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(255,255,255,0.06);
        backdrop-filter: blur(6px);
        background: transparent;
        color: #fff;
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
    }

        /* placeholder */
        .textbox::placeholder {
            color: rgba(255,255,255,0.5);
        }

        /* foco */
        .textbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 12px rgba(72,200,120,0.3);
        }

    /* autocomplete transparente Chrome/Safari */
    input.textbox:-webkit-autofill,
    input.textbox:-webkit-autofill:hover,
    input.textbox:-webkit-autofill:focus,
    input.textbox:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0px 1000px transparent inset !important;
        -webkit-text-fill-color: #fff !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    /* autocomplete transparente Firefox */
    input.textbox:-moz-autofill {
        box-shadow: 0 0 0px 1000px transparent inset !important;
        -moz-text-fill-color: #fff !important;
    }

    /* link verde */
    .link-green {
        color: #48c878;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        transition: color 0.3s ease;
    }

        .link-green:hover {
            color: #32a060;
        }

    /* Combobox estilo igual ao textbox */
    .selectbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(255,255,255,0.25);
        backdrop-filter: blur(6px);
        background: transparent;
        color: rgba(0,0,0);
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
        appearance: none; /* remove a setinha padrão */
        -webkit-appearance: none; /* Safari/Chrome */
        -moz-appearance: none; /* Firefox */
        cursor: pointer;
    }

        /* Ícone de seta customizado */
        .selectbox::-ms-expand {
            display: none; /* remove seta no IE */
        }

        /* Opções do dropdown */
        .selectbox option {
            background-color: rgba(20, 20, 20, 0.95); /* fundo escuro */
            color: #fff; /* texto branco */
        }

        /* Foco */
        .selectbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 10px rgba(72,200,120,0.4);
        }
</style>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<div class="text-center">

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }
</div>

<div class="container-fluid">
    <div class="row">

        <!-- 🔹 LADO ESQUERDO – FORMULÁRIO -->
        <div class="col-md-5">
            <div class="text-center mb-4">
                <h1 class="fs-3 custom-border d-inline-block">Adicionar Entrada</h1>
            </div>

            <form asp-controller="Entrada" asp-action="Criar" method="post">

                <div class="row form-group-spacing align-items-center">
                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Tabernáculo</label>
                        <div class="col-12 col-sm-6">
                            <select asp-for="EntradaNome.AgenciaId" asp-items="Model.EntradaNome.ListaAgencias" class="selectbox">
                                <option value="">-- Selecione --</option>
                            </select>
                            @Html.ValidationMessageFor(x => x.EntradaNome.AgenciaId)
                        </div>
                    </div>

                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Tipo de entrada</label>
                        <div class="col-12 col-sm-6">
                            <select asp-for="EntradaNome.TipoEntradaId" asp-items="Model.EntradaNome.ListaTipos" class="selectbox">
                                <option value="">-- Selecione --</option>
                            </select>
                            @Html.ValidationMessageFor(x => x.EntradaNome.TipoEntradaId)
                        </div>
                    </div>

                    <div class="row form-group-spacing" id="linhaDiv">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Linha</label>
                        <div class="col-12 col-sm-6">
                            <select asp-for="EntradaNome.LinhaId"
                                    asp-items="Model.EntradaNome.ListaLinhas"
                                    class="selectbox">
                                <option value="">-- Selecione --</option>
                            </select>
                            @Html.ValidationMessageFor(x => x.EntradaNome.LinhaId)
                        </div>
                    </div>

                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Conta</label>
                        <div class="col-12 col-sm-6">
                            <select asp-for="EntradaNome.ContaId" asp-items="Model.EntradaNome.ListaContas" class="selectbox">
                                <option value="">-- Selecione --</option>
                            </select>
                            @Html.ValidationMessageFor(x => x.EntradaNome.ContaId)
                        </div>
                    </div>

                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Contribuinte</label>
                        <div class="col-12 col-sm-6">
                            <select asp-for="EntradaNome.CadastroId" asp-items="Model.EntradaNome.ListaCadastros" class="selectbox">
                                <option value="">-- Selecione --</option>
                            </select>
                            @Html.ValidationMessageFor(x => x.EntradaNome.CadastroId)
                        </div>
                    </div>

                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Descrição</label>
                        <div class="col-12 col-sm-6">
                            <textarea asp-for="EntradaNome.Descricao"
                                      class="form-control"
                                      rows="1"
                                      style="overflow:hidden; resize:none;"
                                      placeholder="Digite a descrição"
                                      oninput="this.style.height = ''; this.style.height = this.scrollHeight + 'px'"></textarea>

                            @Html.ValidationMessageFor(x => x.EntradaNome.Descricao)
                        </div>
                    </div>

                    <div class="row form-group-spacing">
                        <label class="col-12 col-sm-4 col-form-label text-sm-end">Valor</label>
                        <div class="col-12 col-sm-6">
                            <input type="number" asp-for="EntradaNome.Valor" class="textbox" />
                            @Html.ValidationMessageFor(x => x.EntradaNome.Valor)
                        </div>
                    </div>
                    <!-- Botão ocupa 4 colunas -->
                    <div class="d-flex justify-content-between mt-5">
                        <button type="submit" class="btn primary">Adicionar</button>
                    </div>
                </div>

            </form>
        </div>


        <!-- 🔹 LADO DIREITO – TABELA -->
        <div class="col-md-7">
            <div class="form-container">

                <div class="text-center mb-5">
                    <h1 class="fs-3 custom-border d-inline-block">
                        Lista de entradas de hoje
                    </h1>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped" id="table-usuarios">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Tabernáculo</th>
                                <th>Tipo</th>
                                <th>Contribuinte</th>
                                <th>Descrição</th>
                                <th>Valor</th>
                                <th>Data</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.ListaEntradas.Any())
                            {
                                @foreach (var cargo in Model.ListaEntradas ?? new List<EntradaModel>())
                                {
                                    <tr>
                                        <td>@cargo.Id</td>
                                        <td>@cargo.Agencia?.Nome</td>
                                        <td>@cargo.TipoEntrada?.Nome</td>
                                        <td>@cargo.Cadastro?.Nome</td>
                                        <td>@cargo.Descricao</td>
                                        <td>@cargo.Valor</td>
                                        <td>@cargo.DataCadastro.ToString("dd/MM/yyyy")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6">Nenhum dado encontrado</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        var tipoSelect = document.getElementById("EntradaNome_TipoEntradaId");
        var linhaDiv = document.getElementById("linhaDiv");
        var linhaSelect = document.getElementById("EntradaNome_LinhaId");

        function controlarLinha() {
            linhaDiv.style.display = "none"; // sempre oculto

            if (tipoSelect.value === "7") {
                linhaSelect.value = "2";
            } else {
                linhaSelect.value = "1";
            }
        }

        tipoSelect.addEventListener("change", controlarLinha);
        controlarLinha(); // ao carregar
    });
</script>