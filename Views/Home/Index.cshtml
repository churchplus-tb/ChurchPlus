    .form-check-input {
        appearance: none;
        -webkit-appearance: none;
        background-color: white;
        border: 2px solid black;
        width: 18px;
        height: 18px;
        border-radius: 3px;
        cursor: pointer;
        position: relative;
        transition: all 0.2s ease;
    }

        /* Quando o checkbox estiver marcado */
        .form-check-input:checked {
            background-color: black;
            border-color: black;
        }

            /* Adiciona o símbolo de check (✓) dentro */
            .form-check-input:checked::after {
                content: '✓';
                color: white;
                font-size: 13px;
                position: absolute;
                top: 0;
                left: 3px;
            }

