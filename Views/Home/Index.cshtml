            border: 1px solid rgba(0,64,0);
        }

        .btn.ghost3 {
            background: transparent;
            color: rgba(0,0,0);
            border: 1px solid rgba(72,0,120);
        }

        .btn.ghost4 {
            background: transparent;
            color: rgba(0,0,0);
            border: 1px solid rgba(64,64,0);
        }
        .btn.ghost5 {
            background: transparent;
            color: rgba(0,0,0);
            border: 1px solid rgba(64,0,0);
        }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }   
    /* textbox */
    .textbox {
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 400;
        border: 1px solid rgba(133,146,141);
        backdrop-filter: blur(6px);
        background: transparent;
        color: rgba(0,0,0);
        font-family: inherit;
        font-size: 16px;
        width: 100%;
        box-sizing: border-box;
        transition: all 0.3s ease;
    }

        /* placeholder */
        .textbox::placeholder {
            color: rgba(255,255,255,0.3);
        }

        /* foco */
        .textbox:focus {
            outline: none;
            border: 1px solid #48c878;
            box-shadow: 0 0 12px rgba(72,200,120,0.3);
        }

    /* autocomplete transparente Chrome/Safari */
    input.textbox:-webkit-autofill,
    input.textbox:-webkit-autofill:hover,
    input.textbox:-webkit-autofill:focus,
    input.textbox:-webkit-autofill:active {
        -webkit-box-shadow: 0 0 0px 1000px transparent inset !important;
        -webkit-text-fill-color: rgba(0,0,0) !important;
        transition: background-color 5000s ease-in-out 0s;
    }

    /* autocomplete transparente Firefox */
    input.textbox:-moz-autofill {
        box-shadow: 0 0 0px 1000px transparent inset !important;
        -moz-text-fill-color: rgba(0,0,0) !important;
    }

