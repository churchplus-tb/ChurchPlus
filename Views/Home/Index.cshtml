<div class="cards-container">
    <div class="card-box4">
        <div class="card-header">Entradas Totais</div>
        <div class="card-sub4">MZN @ViewBag.TotalEntradaAno (Global)</div>

        <div style="width: 100%; margin: 0 auto;">
            <canvas id="grafEntradasAno" style="width: 100% !important; height: 300px;"></canvas>
        </div>
    </div>

    <div class="card-box5">
        <div class="card-header">Saídas Totais</div>
        <div class="card-sub5">MZN @ViewBag.TotalSaidaAno (Global)</div>

        <!-- Gráfico das saídas -->
        <div style="width: 100%; margin: 0 auto;">
            <canvas id="grafSaidasAno" style="width: 100% !important; height: 300px;"></canvas>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Meses
    const meses = ["Jan", "Fev", "Mar", "Abr", "Mai", "Jun",
        "Jul", "Ago", "Set", "Out", "Nov", "Dez"];

    // Valores vindos do ViewBag
    const valores = [
    @string.Join(",", ((List<decimal>)ViewBag.EntradasMesValores))
        ];

    // Criação do gráfico
    const ctx = document.getElementById('grafEntradasAno').getContext('2d');

    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: meses,
            datasets: [{
                label: 'Entradas mensais',
                data: valores,
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: { beginAtZero: true }
            }
        }
    });

    //Saidas

    const valoresSaidas = [
    @string.Join(",", ((List<decimal>)ViewBag.SaidasMesValores))
        ];

    const ctxSaidas = document.getElementById('grafSaidasAno').getContext('2d');

    new Chart(ctxSaidas, {
        type: 'bar',
        data: {
            labels: meses,
            datasets: [{
                label: 'Saídas mensais',
                data: valoresSaidas,
                borderWidth: 1,
                backgroundColor: 'rgba(255, 99, 132, 0.6)' // opcional: cor diferente das entradas
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: { beginAtZero: true }
            }
        }
    });

    const btnMenu = document.getElementById("btnMenuLateral");
    const menu = document.getElementById("menuLateral");
    let aberto = false;

    btnMenu.onclick = function () {
        if (!aberto) {
            menu.style.left = "0px";
            aberto = true;
        } else {
            menu.style.left = "-260px";
            aberto = false;
        }
    };

    // Submenus
    const toggles = document.querySelectorAll(".submenu-toggle");
    toggles.forEach(toggle => {
        toggle.addEventListener("click", function () {
            const submenu = this.nextElementSibling;
            if (submenu.style.display === "none" || submenu.style.display === "") {
                submenu.style.display = "block";
            } else {
                submenu.style.display = "none";
            }
        });
    });
</script>