        <li class="has-submenu">
            <a href="javascript:void(0);" class="submenu-toggle">Operações ▾</a>
            <ul class="submenu" style="display:none; list-style:none; padding-left:15px;">
               
                @if (ViewBag.EstadoDia == 1)
                {
                    <li><a asp-controller="Entrada" asp-action="Criar">Entradas</a></li>
                    <li><a asp-controller="Saida" asp-action="Criar">Saídas</a></li>
                }

                <li><a asp-controller="Inventario" asp-action="Criar">Inventário</a></li>
                <li><a asp-controller="ContasCobrar" asp-action="Criar">Contas a cobrar</a></li>
                <li><a asp-controller="ContasPagar" asp-action="Criar">Contas a pagar</a></li>
            </ul>
        </li>
        <li class="has-submenu">
            <a href="javascript:void(0);" class="submenu-toggle">Saldos ▾</a>
            <ul class="submenu" style="display:none; list-style:none; padding-left:15px;">
                <li><a asp-controller="Conta" asp-action="Criar">Contas</a></li>
                <li><a asp-controller="Linha" asp-action="Criar">Linhas</a></li>
                <li><a asp-controller="Agencia" asp-action="Index">Tabernáculos</a></li>
            </ul>
        </li>
        @if (ViewBag.Perfil == Analise.Enuns.PerfilEnum.Admin)
        {
            
            <li class="has-submenu">
