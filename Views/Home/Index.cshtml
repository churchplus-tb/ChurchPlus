                    <li><a asp-controller="Estado" asp-action="Criar">Estados</a></li>
                    <li><a asp-controller="TipoDespesa" asp-action="Criar">Despesas</a></li>
                    <li><a asp-controller="TipoServico" asp-action="Criar">Serviços</a></li>
                    <li><a asp-controller="TipoEntrada" asp-action="Criar">Entradas</a></li>
                    <li><a asp-controller="TipoSaida" asp-action="Criar">Saídas</a></li>
                    <li><a asp-controller="Usuario" asp-action="Index">Usuários</a></li>
                </ul>
            </li>
        }
        

        <li><a asp-controller="Cadastro" asp-action="Criar">Pessoas</a></li>
        <li><a asp-controller="Entrada" asp-action="RelatorioEntradas">Relatórios</a></li>        
        <li><a asp-controller="AlterarSenha" asp-action="Index">Senha</a></li>
        @if (ViewBag.EstadoDia == null)
        {
            <!-- 🔓 ABRIR DIA -->
            <li>
                <form asp-controller="Home" asp-action="AbrirDia" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0 m-0">
                        Abrir o dia
                    </button>
                </form>
            </li>
        }
        else if (ViewBag.EstadoDia == 1)
        {
            <!-- 🔒 FECHAR DIA -->
            <li>
                <form asp-controller="Home" asp-action="FecharDia" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0 m-0 text-danger">
                        Fechar o dia
                    </button>
                </form>
            </li>
        }
        <!-- EstadoId == 2 → não mostra nada -->
        <li><a asp-controller="Login" asp-action="Sair">Sair</a></li>
    </ul>

</div>


